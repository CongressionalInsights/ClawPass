{
  "name": "clawpass-full",
  "allowed_surface": [
    ".gitignore",
    "README.md",
    "pyproject.toml",
    "Dockerfile",
    "docker-compose.yml",
    "docs/*",
    "examples/*",
    "src/clawpass_server/*",
    "src/clawpass_server/*/*",
    "src/clawpass_sdk_py/*",
    "src/ledgerclaw_server/*",
    "src/ledgerclaw_sdk_py/*",
    "tests/*",
    "ts-sdk/*",
    "ts-sdk/*/*",
    "scripts/repo_autoresearch_eval.py",
    "scripts/check_sdk_roundtrip.py",
    "autoresearch/*"
  ],
  "benchmarks": [
    {
      "id": "pytest",
      "command": "pytest -q",
      "weight": 1.0
    },
    {
      "id": "compileall",
      "command": "python3 -m compileall src tests examples scripts",
      "weight": 0.5
    },
    {
      "id": "sdk_roundtrip",
      "command": "python3 scripts/check_sdk_roundtrip.py",
      "weight": 0.75
    }
  ]
}
